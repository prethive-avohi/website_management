  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "source_file",
      "fieldtype": "Attach",
      "label": "Upload Document (PDF / Word)",
      "reqd": 1,
      "description": "Upload a .pdf or .docx file to extract content from"
    },
    {
      "fieldname": "page_type",
      "fieldtype": "Select",
      "label": "Page Type",
      "options": "Landing Page\nBlog Post\nWeb Page",
      "default": "Web Page",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "audience",
      "fieldtype": "Select",
      "label": "Audience",
      "options": "All\nUniversities\nStudents\nConsultants",
      "default": "All"
    },
    {
      "fieldname": "slug",
      "fieldtype": "Data",
      "label": "Slug",
      "description": "URL path for the generated page (auto-generated from title if left blank)"
    },
    {
      "fieldname": "sb_generation",
      "fieldtype": "Section Break",
      "label": "Generation"
    },
    {
      "default": "Pending",
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nExtracting\nGenerating\nCompleted\nFailed",
      "in_list_view": 1,
      "read_only": 1
    },
    {
      "fieldname": "sb_extracted",
      "fieldtype": "Section Break",
      "label": "Extracted Content",
      "collapsible": 1
    },
    {
      "fieldname": "extracted_text",
      "fieldtype": "Long Text",
      "label": "Extracted Text",
      "read_only": 1
    },
    {
      "fieldname": "sb_generated",
      "fieldtype": "Section Break",
      "label": "Generated Content",
      "collapsible": 1
    },
    {
      "fieldname": "generated_content",
      "fieldtype": "Long Text",
      "label": "Generated Content (JSON)",
      "read_only": 1
    },
    {
      "fieldname": "sb_error",
      "fieldtype": "Section Break",
      "label": "Error Log",
      "collapsible": 1,
      "depends_on": "eval:doc.status=='Failed'"
    },
    {
      "fieldname": "error_log",
      "fieldtype": "Code",
      "label": "Error Log",
      "read_only": 1
    }
  ],
